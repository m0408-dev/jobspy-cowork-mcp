# Copy to .env for local runs:  cp .env.example .env

# Transport: "stdio" for local testing / Claude Desktop / Claude Code,
#            "http"  for the public Cowork connector.
MCP_TRANSPORT=stdio

# --- HTTP mode only ---
HOST=0.0.0.0
PORT=8000
# Secret-ish endpoint path. CHANGE the random part — this is your access guard for Cowork,
# so that only someone who knows the full URL can reach the server.
MCP_HTTP_PATH=/mcp-CHANGE-ME-9f3a2b/
# Optional bearer token (advanced; some clients need it). Leave empty to use the secret path only.
# MCP_AUTH_TOKEN=

# --- Proxies ---
# REQUIRED for reliable cloud scraping: LinkedIn/Glassdoor/Indeed block datacenter IPs.
# Not needed when running locally from your home connection.
# Comma-separated, JobSpy format: user:pass@host:port
# JOBSPY_PROXIES=user:pass@gate.example.com:7000,user:pass@gate.example.com:7001

LOG_LEVEL=INFO
